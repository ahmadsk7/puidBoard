# Web App Environment Variables - Local Development
# This file is for local development only. Do NOT commit to git.

# Use mock room for local development (no server needed)
# Set to "false" to connect to real realtime server
NEXT_PUBLIC_USE_MOCK_ROOM=true

# Realtime Server URL - for local development (when USE_MOCK_ROOM=false)
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001

# Supabase (optional - used for track storage in production)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
